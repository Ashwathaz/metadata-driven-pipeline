pipeline {
    agent any

    environment {
        APP_NAME = 'ai-app'
        DOCKER_IMAGE = "app:${BUILD_NUMBER}"
    }

    stages {
        stage('Pre-check') {
            steps {
                script {
                    def metadataExists = fileExists('config/metadata.json')
                    def codeExists = fileExists('app/index.html')

                    if (!metadataExists && !codeExists) {
                        error("Waiting for Implementation and Development Teams")
                    } else if (metadataExists && !codeExists) {
                        error("Waiting for Development Team")
                    } else if (!metadataExists && codeExists) {
                        error("Waiting for Implementation Team")
                    } else {
                        echo "Both metadata and code exist. Proceeding with pipeline."
                    }
                }
            }
        }

        stage('Read Metadata') {
            steps {
                script {
                    env.METADATA_PORT = readJSON(file: 'config/metadata.json').port
                }
            }
        }

        stage('Validation') {
            steps {
                script {
                    echo "Running validation script..."
                    if (isUnix()) {
                        sh 'python3 validator/validator.py'
                    } else {
                        bat 'python validator/validator.py'
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    if (isUnix()) {
                        sh "docker build -t ${DOCKER_IMAGE} -f docker/Dockerfile ."
                    } else {
                        bat "docker build -t ${DOCKER_IMAGE} -f docker/Dockerfile ."
                    }
                }
            }
        }

        stage('Deploy Container') {
            steps {
                script {
                    if (isUnix()) {
                        sh """
                            docker stop ${APP_NAME} || true
                            docker rm -f ${APP_NAME} || true
                            docker run -d -p ${METADATA_PORT}:80 --name ${APP_NAME} ${DOCKER_IMAGE}
                        """
                    } else {
                        bat """
                            docker stop ${APP_NAME} || echo .
                            docker rm -f ${APP_NAME} || echo .
                            docker run -d -p ${METADATA_PORT}:80 --name ${APP_NAME} ${DOCKER_IMAGE}
                        """
                    }
                }
            }
        }

        stage('Print Public URL') {
            steps {
                script {
                    def publicIp = ""
                    if (isUnix()) {
                        publicIp = sh(script: 'curl -s ifconfig.me', returnStdout: true).trim()
                    } else {
                        // Extracting ip directly
                        publicIp = bat(script: '@powershell -Command "(Invoke-WebRequest -UseBasicParsing -Uri http://ifconfig.me).Content"', returnStdout: true).trim()
                    }
                    echo "🚀 App deployed at: http://${publicIp}:${METADATA_PORT}"
                }
            }
        }
    }
}
