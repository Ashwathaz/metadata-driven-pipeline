pipeline {
    agent any
    
    triggers {
        pollSCM('* * * * *')
    }
    
    environment {
        DOCKER_IMAGE = "app"
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Pre-check') {
            steps {
                script {
                    def metadataExists = fileExists('config/metadata.json')
                    def codeExists = fileExists('app/index.html')
                    
                    if (!metadataExists && !codeExists) {
                        error("Waiting for Implementation and Development Teams")
                    } else if (!metadataExists) {
                        error("Waiting for Implementation Team")
                    } else if (!codeExists) {
                        error("Waiting for Development Team")
                    } else {
                        echo "Both metadata and code exist. Proceeding pipeline..."
                    }
                }
            }
        }
        
        stage('Read Metadata') {
            steps {
                script {
                    def metadata = readJSON file: 'config/metadata.json'
                    echo "Loaded Metadata for ${metadata.app_name} version ${metadata.version}"
                }
            }
        }
        
        stage('Validation') {
            steps {
                script {
                    sh 'python3 validator/validator.py'
                }
            }
        }
        
        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -f docker/Dockerfile ."
                }
            }
        }
        
        stage('Tag Image') {
            steps {
                script {
                    sh "docker tag ${DOCKER_IMAGE}:${BUILD_NUMBER} ${DOCKER_IMAGE}:latest"
                }
            }
        }
        
        stage('Deploy to Kubernetes') {
            steps {
                script {
                    echo "--- Kubernetes Authentication Setup ---"
                    // Bind Jenkins kubeconfig file credential to KUBECONFIG environment variable securely
                    withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                        
                        echo "--- Debug: Kubeconfig View ---"
                        sh "kubectl config view"
                        
                        echo "--- Debug: Fetching Nodes before Deploy ---"
                        def clusterCheck = sh(script: "kubectl get nodes", returnStatus: true)
                        if (clusterCheck != 0) {
                            error "FATAL: Kubernetes cluster is unreachable or authentication was rejected. Verify the 'kubeconfig' credential in Jenkins Settings."
                        }
                        
                        echo "--- Applying Deployment Resources ---"
                        def deployCheck = sh(script: "kubectl apply -f k8s/deployment.yaml", returnStatus: true)
                        if (deployCheck != 0) {
                            echo "Warning: Standard apply failed. Executing fallback with --validate=false..."
                            def fallbackCheck = sh(script: "kubectl apply --validate=false -f k8s/deployment.yaml", returnStatus: true)
                            if (fallbackCheck != 0) {
                                error "FATAL: Deployment aborted. Resilient fallback also failed applying k8s/deployment.yaml."
                            }
                        }
                        
                        def serviceCheck = sh(script: "kubectl apply -f k8s/service.yaml", returnStatus: true)
                        if (serviceCheck != 0) {
                            error "FATAL: Failed to apply k8s/service.yaml."
                        }
                        
                        echo "✅ Kubernetes deployment successfully concluded."
                    }
                }
            }
        }
        
        stage('Print Public URL') {
            steps {
                script {
                    def publicIp = sh(script: 'curl -s ifconfig.me', returnStdout: true).trim()
                    echo "🚀 App deployed at: http://${publicIp}:30007"
                }
            }
        }
    }
}
